<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="750" style="-fx-background-color: #f5f7fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AjouterJustificatif">

    <!-- Header avec logo et titre -->
    <HBox alignment="CENTER_LEFT" layoutX="20" layoutY="20" spacing="15" style="-fx-padding:10;">
        <ImageView fx:id="logoView" fitHeight="80" fitWidth="80" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@images/logo.png" />
            </image>
        </ImageView>
        <Label style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#2C3E50;                       -fx-effect: dropshadow( gaussian , rgba(0,0,0,0.25) , 2,0,0,1 );" text="📝 Ajouter Une Jutificatif" />
    </HBox>

    <!-- Formulaire central -->
    <GridPane alignment="TOP_CENTER" hgap="20" layoutX="50.0" layoutY="130.0" vgap="15">
        <padding>
            <Insets bottom="20" left="40" right="40" top="20" />
        </padding>

        <!-- Date -->
        <Label style="-fx-font-weight:bold; -fx-font-size:14px;" text="Date :" GridPane.rowIndex="0" />
        <DatePicker fx:id="dateField" style="-fx-background-radius:8; -fx-padding:6; -fx-border-color:#d1d9e6; -fx-border-radius:8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <!-- Catégorie -->
        <Label style="-fx-font-weight:bold; -fx-font-size:14px;" text="Type fichier :" GridPane.rowIndex="1" />

        <!-- Montant -->
        <Label style="-fx-font-weight:bold; -fx-font-size:14px;" text="Chemin :" GridPane.rowIndex="2" />
        <TextField fx:id="cheminField" style="-fx-background-radius:8; -fx-padding:6; -fx-border-color:#d1d9e6; -fx-border-radius:8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <!-- Description -->
        <Label style="-fx-font-weight:bold; -fx-font-size:14px;" text="Télécharger fichier :" GridPane.rowIndex="4" />

        <!-- Boutons -->
        <HBox alignment="CENTER_RIGHT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="5">
            <Button fx:id="btnAjouter" onAction="#ajouterD" style="-fx-background-color:#2C3E50; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" text="Ajouter" />
            <Button onAction="#naviguer" style="-fx-background-color:#28A745; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" text="Retour" />
        </HBox>
      <TextField fx:id="typeField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
      <Button fx:id="btnParcourir" mnemonicParsing="false" onAction="#uploadFile" text="Parcourir..." GridPane.columnIndex="1" GridPane.rowIndex="4" />
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

</AnchorPane>
