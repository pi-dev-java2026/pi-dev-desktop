<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="user.controllers.UserListeQuiz"
            stylesheets="@/app.css"
            prefWidth="1050.0" prefHeight="650.0">

    <left>
        <VBox prefWidth="230.0" styleClass="sidebar">
            <Label text="DINARI" styleClass="brand"/>
            <Label text="STUDENT PORTAL" styleClass="brand-sub"/>

            <Separator opacity="0.2"/>

            <Button text="🏠 Accueil" styleClass="nav-btn" onAction="#goHome"/>
            <Button text="📚 Éducative" styleClass="nav-btn nav-btn-active" onAction="#goEducation"/>
            <Button text="💳 Abonnements" styleClass="nav-btn"/>
            <Button text="💰 Dépenses" styleClass="nav-btn"/>
            <Button text="📊 Budget" styleClass="nav-btn"/>
            <Button text="👤 Profile" styleClass="nav-btn"/>
            <Button text="📢 Réclamation" styleClass="nav-btn"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Label text="Étudiant" styleClass="sidebar-footer"/>
            <Label text="student@dinari.com" styleClass="sidebar-footer"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Tous les Quiz Disponibles" styleClass="page-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Rafraîchir" styleClass="ghost-btn" onAction="#refresh"/>
            </HBox>

            <HBox styleClass="toolbar" alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="tfSearch"
                           promptText="Rechercher un quiz..."
                           styleClass="input"
                           HBox.hgrow="ALWAYS"/>

                <Button text="Appliquer" styleClass="primary-btn" onAction="#apply"/>
                <Button text="Reset" styleClass="ghost-btn" onAction="#reset"/>
            </HBox>

            <ListView fx:id="listViewQuiz" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

</BorderPane>
