<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" styleClass="dashboard-root" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Fintech.controllers.UserProfileController">
   
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="220.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-logo">
               <children>
                  <Label styleClass="logo-icon" text="D" />
                  <Label styleClass="logo-text" text="DINARI" />
               </children>
               <VBox.margin>
                  <Insets bottom="40.0" left="20.0" right="20.0" top="30.0" />
               </VBox.margin>
            </HBox>
            
            <!-- Menu Items -->
            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-menu-item" text="📊  Dashboard">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleTransactions" styleClass="sidebar-menu-item" text="💳  Transactions">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleBudgets" styleClass="sidebar-menu-item" text="💰  Budgets">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleUsers" styleClass="sidebar-menu-item, sidebar-menu-item-active" text="👥  Utilisateurs">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleReclamations" styleClass="sidebar-menu-item" text="📝  Réclamations">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleSettings" styleClass="sidebar-menu-item" text="⚙️  Paramètres">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
            
            <!-- Logout Button -->
            <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-menu-item, logout-btn" text="🚪  Déconnexion">
               <VBox.margin>
                  <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" BorderPane.alignment="CENTER">
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" styleClass="content-header">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="page-title" text="Profil Utilisateur" />
                        <Label styleClass="page-subtitle" text="Détails complets de l'utilisateur sélectionné." />
                     </children>
                  </VBox>
                  
                  <!-- User Profile -->
                  <HBox alignment="CENTER" spacing="10.0" styleClass="user-profile">
                     <children>
                        <VBox alignment="CENTER_RIGHT">
                           <children>
                              <Label fx:id="profileNameLabel" styleClass="profile-name" text="Utilisateur" />
                              <Label fx:id="profileRoleLabel" styleClass="profile-role" text="Role" />
                           </children>
                        </VBox>
                        <Label styleClass="profile-avatar" text="👤" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
               </padding>
            </HBox>
            
            <!-- Back Button -->
            <HBox alignment="CENTER_LEFT" styleClass="table-header-section">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBack" styleClass="add-user-btn" text="← Retour à la liste">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
               </padding>
            </HBox>
            
            <!-- User Details Card -->
            <VBox styleClass="users-table" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="30.0" left="30.0" right="30.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               
               <children>
                  <!-- User Avatar and Name -->
                  <HBox alignment="CENTER" spacing="20.0">
                     <VBox.margin>
                        <Insets bottom="30.0" />
                     </VBox.margin>
                     <children>
                        <Label style="-fx-font-size: 48px; -fx-background-color: #e5e7eb; -fx-background-radius: 50%; -fx-padding: 20;" text="👤" />
                        <VBox alignment="CENTER">
                           <children>
                              <Label fx:id="userNameLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Nom Utilisateur" />
                              <Label fx:id="userRoleBadge" styleClass="role-badge" style="-fx-font-size: 13px; -fx-padding: 6 18;" text="Role">
                                 <VBox.margin>
                                    <Insets top="10.0" />
                                 </VBox.margin>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <!-- Separator -->
                  <Separator>
                     <VBox.margin>
                        <Insets bottom="30.0" top="10.0" />
                     </VBox.margin>
                  </Separator>
                  
                  <!-- User Information Grid -->
                  <GridPane hgap="40.0" vgap="25.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="150.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="300.0" />
                     </columnConstraints>
                     
                     <!-- ID -->
                     <Label style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-font-size: 14px;" text="ID Utilisateur:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                     <Label fx:id="userIdLabel" style="-fx-text-fill: #1f2937; -fx-font-size: 14px;" text="#123" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                     
                     <!-- Name -->
                     <Label style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Nom complet:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                     <Label fx:id="userNameDetailLabel" style="-fx-text-fill: #1f2937; -fx-font-size: 14px;" text="Nom Utilisateur" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     
                     <!-- Email -->
                     <Label style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                     <Label fx:id="userEmailLabel" style="-fx-text-fill: #1f2937; -fx-font-size: 14px;" text="email@example.com" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                     
                     <!-- Phone -->
                     <Label style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                     <Label fx:id="userPhoneLabel" style="-fx-text-fill: #1f2937; -fx-font-size: 14px;" text="+216 12 345 678" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                     
                     <!-- Password -->
                     <Label style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Mot de passe:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                     <Label style="-fx-text-fill: #999; -fx-font-size: 14px;" text="🔒 • • • • • • • •" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                     
                     <!-- Role -->
                     <Label style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Rôle:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                     <Label fx:id="userRoleLabel" style="-fx-text-fill: #1f2937; -fx-font-size: 14px;" text="User" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  </GridPane>
                  
                  <!-- Separator -->
                  <Separator>
                     <VBox.margin>
                        <Insets bottom="30.0" top="30.0" />
                     </VBox.margin>
                  </Separator>
                  
                  <!-- Action Buttons -->
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <Button fx:id="editButton" mnemonicParsing="false" onAction="#handleEdit" styleClass="add-user-btn" text="✏️  Modifier l'utilisateur">
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                        </Button>
                        
                        <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDelete" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;" text="🗑️  Supprimer l'utilisateur">
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
