<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" styleClass="dashboard-root" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Fintech.controllers.ReclamationManagementController">
   
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="220.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-logo">
               <children>
                  <Label styleClass="logo-icon" text="D" />
                  <Label styleClass="logo-text" text="DINARI" />
               </children>
               <VBox.margin>
                  <Insets bottom="40.0" left="20.0" right="20.0" top="30.0" />
               </VBox.margin>
            </HBox>
            
            <!-- Menu Items -->
            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-menu-item" text="📊  Dashboard">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleTransactions" styleClass="sidebar-menu-item" text="💳  Transactions">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleBudgets" styleClass="sidebar-menu-item" text="💰  Budgets">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleUsers" styleClass="sidebar-menu-item" text="👥  Utilisateurs">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" styleClass="sidebar-menu-item, sidebar-menu-item-active" text="📝  Réclamations">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
                  
                  <Button mnemonicParsing="false" onAction="#handleSettings" styleClass="sidebar-menu-item" text="⚙️  Paramètres">
                     <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
            
            <!-- Logout Button -->
            <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-menu-item, logout-btn" text="🚪  Déconnexion">
               <VBox.margin>
                  <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" BorderPane.alignment="CENTER">
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" styleClass="content-header">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="page-title" text="Gestion des Réclamations" />
                        <Label styleClass="page-subtitle" text="Visualisez et gérez l'ensemble des réclamations de la plateforme Dinari." />
                     </children>
                  </VBox>
                  
                  <!-- Search Bar -->
                  <TextField fx:id="searchField" onKeyReleased="#handleSearch" promptText="🔍 Rechercher Une réclammation..." styleClass="search-field">
                     <HBox.margin>
                        <Insets right="20.0" />
                     </HBox.margin>
                  </TextField>
                  
                  <!-- User Profile -->
                  <HBox alignment="CENTER" spacing="10.0" styleClass="user-profile">
                     <children>
                        <VBox alignment="CENTER_RIGHT">
                           <children>
                              <Label fx:id="profileNameLabel" styleClass="profile-name" text="Utilisateur" />
                              <Label fx:id="profileRoleLabel" styleClass="profile-role" text="Role" />
                           </children>
                        </VBox>
                        <Label styleClass="profile-avatar" text="👤" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
               </padding>
            </HBox>
            
            <!-- Table Header with Add Button -->
            <HBox alignment="CENTER_LEFT" styleClass="table-header-section">
               <children>
                  <Label fx:id="totalReclamationsLabel" styleClass="table-title" text="Liste des Réclamations" />
                  <Label fx:id="reclamationCountLabel" styleClass="user-count" text="0 Total" />
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <Button mnemonicParsing="false" onAction="#handleCreateReclamation" styleClass="add-user-btn" text="📝  Créer une réclamation" />
               </children>
               <padding>
                  <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
               </padding>
            </HBox>
            
            <!-- Reclamations List -->
            <ListView fx:id="reclamationsList" styleClass="users-list" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="30.0" left="30.0" right="30.0" />
               </VBox.margin>
            </ListView>
         </children>
      </VBox>
   </center>
</BorderPane>
