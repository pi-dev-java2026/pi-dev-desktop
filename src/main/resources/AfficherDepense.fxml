<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600" prefWidth="900"
            style="-fx-background-color: linear-gradient(to bottom right, #f0f4f7, #d9e2ec);"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AfficherDepense">

    <top>
        <Region/>
    </top>

    <!-- ✅ Sidebar -->
    <left>
        <VBox prefWidth="235" minWidth="235"
              style="-fx-background-color: #0f1f3d;">

            <VBox alignment="CENTER" prefHeight="115"
                  style="-fx-background-color: #0a1628; -fx-padding: 18;">
                <Label text="DINARI"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Gestion Financière"
                       style="-fx-font-size: 10px; -fx-text-fill: #3d5f8a;"/>
            </VBox>

            <Separator style="-fx-background-color: #1a3055;"/>

            <VBox spacing="3" style="-fx-padding: 18 10 0 10;">

                <Button fx:id="btnAbonnements" text="📺   Abonnements" maxWidth="Infinity"
                        onAction="#showAbonnement"
                        style="-fx-background-color: transparent; -fx-text-fill: #6a8aaa;
                               -fx-font-size: 12px; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Button fx:id="btnEducation" text="📚   Éducative" maxWidth="Infinity"
                        onAction="#showEducative"
                        style="-fx-background-color: transparent; -fx-text-fill: #6a8aaa;
                               -fx-font-size: 12px; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Button fx:id="btnDepenses" text="💸   Dépenses" maxWidth="Infinity"
                        onAction="#showDepenses"
                        style="-fx-background-color: #1a3a7a; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;
                               -fx-font-weight: bold; -fx-border-color: #2ecc71;
                               -fx-border-width: 0 0 0 3; -fx-border-radius: 0 8 8 0;"/>

                <Button fx:id="btnBudget" text="💰   Budget" maxWidth="Infinity"
                        onAction="#showBudget"
                        style="-fx-background-color: transparent; -fx-text-fill: #6a8aaa;
                               -fx-font-size: 12px; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 12 15; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox style="-fx-padding: 10;">
                <Separator style="-fx-background-color: #1a3055;"/>
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 12 10 5 10;">
                    <Label text="👤" style="-fx-font-size: 18px;"/>
                    <VBox>
                        <Label text="Utilisateur"
                               style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="admin@dinari.tn"
                               style="-fx-text-fill: #3d5f8a; -fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ✅ Center Modern -->
    <center>
        <VBox spacing="14" style="-fx-padding:20;">

            <!-- Header Card -->
            <VBox spacing="6"
                  style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:16;
                         -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.2, 0, 2);">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📋 Liste des Dépenses"
                           style="-fx-font-size:22px; -fx-font-weight:800; -fx-text-fill:#243b53;"/>
                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="📊 Prédiction IA" onAction="#showDashboard"
                            style="-fx-background-color:#2f80ed; -fx-text-fill:white; -fx-font-weight:bold;
                                   -fx-padding:8 14; -fx-background-radius:10; -fx-cursor: hand;"/>

                    <Button text="➕ Ajouter Dépense" onAction="#openAjouterDepense"
                            style="-fx-background-color:#2f80ed; -fx-text-fill:white; -fx-font-weight:bold;
                                   -fx-padding:8 14; -fx-background-radius:10; -fx-cursor: hand;"/>

                    <Button text="Historique" onAction="#HistoriqueDepense"
                            style="-fx-background-color:#f3f4f6; -fx-text-fill:#334e68; -fx-font-weight:bold;
                                   -fx-padding:8 14; -fx-background-radius:10; -fx-cursor: hand;"/>
                </HBox>

                <Label text="La recherche et le tri se font automatiquement."
                       style="-fx-text-fill:#7b8794; -fx-font-size:12px;"/>
            </VBox>

            <!-- Filter Card (بدون button) -->
            <VBox spacing="10"
                  style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:14;
                         -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0.2, 0, 2);">

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <VBox spacing="4">
                        <Label text="Montant" style="-fx-font-weight:700; -fx-text-fill:#52606d;"/>
                        <TextField fx:id="montantField" promptText="Ex: 50"
                                   style="-fx-background-radius:10; -fx-padding:8 10;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Mode de paiement" style="-fx-font-weight:700; -fx-text-fill:#52606d;"/>
                        <ComboBox fx:id="paiementBox" style="-fx-background-radius:10;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Catégorie" style="-fx-font-weight:700; -fx-text-fill:#52606d;"/>
                        <ComboBox fx:id="categorieCombo" style="-fx-background-radius:10;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox spacing="4">
                        <Label text="Trier" style="-fx-font-weight:700; -fx-text-fill:#52606d;"/>
                        <HBox spacing="8">
                            <ComboBox fx:id="triChampCombo" style="-fx-background-radius:10;"/>
                            <ComboBox fx:id="triTypeCombo" style="-fx-background-radius:10;"/>
                        </HBox>
                    </VBox>

                </HBox>
            </VBox>

            <!-- Liste Card -->
            <VBox spacing="10"
                  style="-fx-background-color:white; -fx-background-radius:14; -fx-padding:10;
                         -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0.2, 0, 2);">

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                            style="-fx-background-color:transparent;"
                            vbarPolicy="AS_NEEDED">
                    <content>
                        <VBox fx:id="vboxDepenses" spacing="15" style="-fx-padding:10;">
                            <!-- cartes dynamiques -->
                        </VBox>
                    </content>
                </ScrollPane>

            </VBox>

        </VBox>
    </center>

</BorderPane>