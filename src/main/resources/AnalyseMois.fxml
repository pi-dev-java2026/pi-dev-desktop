<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.AnalyseMoisController">

    <padding>
        <Insets bottom="24" left="24" right="24" top="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="← Retour" onAction="#goBack" styleClass="primary-btn"/>
        <VBox>
            <Label text="Analyse du mois courant" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
            <Label fx:id="monthLabel" text="-" style="-fx-text-fill: #666;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Rafraîchir" onAction="#refresh" styleClass="secondary-btn"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="card">
        <content>
            <VBox fx:id="analysisBox" spacing="10">
                <padding>
                    <Insets bottom="12" left="12" right="12" top="12"/>
                </padding>
            </VBox>
        </content>
    </ScrollPane>

</VBox>