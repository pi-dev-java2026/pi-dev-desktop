<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controllers.GestionabonnementsController"
           style="-fx-background-color: #f5f6fa;">

    <!-- ===== PAGE 1 : LISTE SERVICES ===== -->
    <VBox fx:id="pageListe" style="-fx-background-color: #f5f6fa;">

        <!-- HEADER -->
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-padding: 22 30;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Abonnements"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f1f3d;"/>
                <Label text="Gérez vos paiements récurrents en un clin d'œil."
                       style="-fx-font-size: 12px; -fx-text-fill: #8899aa;"/>
            </VBox>
            <HBox alignment="CENTER" spacing="25">
                <!-- NOUVEAU BOUTON PAIEMENTS -->
                <Button text="💳  Mes Paiements"
                        onAction="#ouvrirPaiements"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 13 28; -fx-background-radius: 10;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(46,204,113,0.4), 8, 0, 0, 3);"/>

                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label text="Total mensuel"
                           style="-fx-font-size: 11px; -fx-text-fill: #8899aa;"/>
                    <Label fx:id="lblTotalMensuel" text="0.00€"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f1f3d;"/>
                </VBox>
                <Button text="＋  Ajouter" onAction="#ouvrirFormulaire"
                        style="-fx-background-color: #1a3a7a; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 13 28; -fx-background-radius: 10;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(26,58,122,0.5), 10, 0, 0, 4);"/>
            </HBox>
        </HBox>

        <!-- RECHERCHE + FILTRES -->
        <HBox spacing="15"
              style="-fx-padding: 15 30; -fx-background-color: white;
                     -fx-border-color: #f0f2f5; -fx-border-width: 0 0 1.5 0;">
            <HBox HBox.hgrow="ALWAYS" spacing="0" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f5f6fa; -fx-background-radius: 10;
                         -fx-border-color: #e0e8f0; -fx-border-width: 1.5;
                         -fx-border-radius: 10; -fx-padding: 0 15;">
                <Label text="🔍" style="-fx-font-size: 14px; -fx-padding: 0 8 0 0;"/>
                <TextField fx:id="txtRecherche"
                           promptText="Rechercher un abonnement..."
                           HBox.hgrow="ALWAYS"
                           onKeyReleased="#appliquerFiltres"
                           style="-fx-background-color: transparent; -fx-border-width: 0;
                                  -fx-padding: 11 0; -fx-font-size: 13px;"/>
            </HBox>
            <ComboBox fx:id="comboFiltreCategorie"
                      promptText="Toutes les catégories"
                      onAction="#appliquerFiltres" prefWidth="200"
                      style="-fx-background-radius: 10; -fx-font-size: 12px;
                             -fx-border-color: #e0e8f0; -fx-border-width: 1.5;
                             -fx-border-radius: 10; -fx-padding: 5;"/>
            <ComboBox fx:id="comboTri"
                      promptText="Trier par..."
                      onAction="#appliquerFiltres" prefWidth="165"
                      style="-fx-background-radius: 10; -fx-font-size: 12px;
                             -fx-border-color: #e0e8f0; -fx-border-width: 1.5;
                             -fx-border-radius: 10; -fx-padding: 5;"/>
        </HBox>


        <!-- LISTE VERTICALE DES SERVICES -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: #f5f6fa; -fx-background-color: #f5f6fa;">
            <VBox fx:id="listeServices" spacing="10" style="-fx-padding: 20 30;"/>
        </ScrollPane>
    </VBox>

    <!-- ===== PAGE 2 : DÉTAIL SERVICE ===== -->
    <VBox fx:id="pageDetailService" visible="false" managed="false"
          style="-fx-background-color: #f5f6fa;">

        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: white; -fx-padding: 20 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
            <Button text="← Retour" onAction="#retourListe"
                    style="-fx-background-color: #f0f4f8; -fx-text-fill: #0f1f3d;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-border-color: #dde3ea; -fx-border-radius: 8; -fx-border-width: 1.5;"/>
            <VBox HBox.hgrow="ALWAYS">
                <Label fx:id="lblServiceNom" text=""
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f1f3d;"/>
                <Label fx:id="lblServiceSousTitre" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #8899aa;"/>
            </VBox>
            <Button text="＋  Nouvel abonnement" onAction="#ouvrirFormulaire"
                    style="-fx-background-color: #1a3a7a; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: #f5f6fa; -fx-background-color: #f5f6fa;">
            <VBox spacing="12" style="-fx-padding: 25;">
                <!-- Infos résumé service -->
                <HBox spacing="15" fx:id="statsService"/>
                <!-- Liste abonnements du service -->
                <VBox fx:id="listeAbonnementsService" spacing="10"/>
            </VBox>
        </ScrollPane>
    </VBox>

    <!-- ===== PAGE 3 : FORMULAIRE AJOUT ===== -->
    <VBox fx:id="pageFormulaire" visible="false" managed="false"
          style="-fx-background-color: #f5f6fa;">

        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: white; -fx-padding: 20 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
            <Button text="← Retour" onAction="#retourListe"
                    style="-fx-background-color: #f0f4f8; -fx-text-fill: #0f1f3d;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-border-color: #dde3ea; -fx-border-radius: 8; -fx-border-width: 1.5;"/>
            <VBox>
                <Label text="Ajouter un Abonnement"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f1f3d;"/>
                <Label text="Remplissez les informations ci-dessous"
                       style="-fx-font-size: 12px; -fx-text-fill: #8899aa;"/>
            </VBox>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: #f5f6fa; -fx-background-color: #f5f6fa;">
            <VBox alignment="TOP_CENTER" style="-fx-padding: 35;">
                <VBox prefWidth="560" spacing="20"
                      style="-fx-background-color: white; -fx-padding: 35;
                             -fx-background-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 4);">

                    <Label text="Informations du service"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f1f3d;"/>
                    <Separator/>

                    <HBox spacing="18">
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Nom du service *"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #445566;"/>
                            <TextField fx:id="txtNom" promptText="Ex: Netflix, Spotify..."
                                       style="-fx-background-radius: 9; -fx-border-radius: 9;
                                              -fx-border-color: #e0e8f0; -fx-border-width: 1.5;
                                              -fx-padding: 11 14; -fx-font-size: 13px;
                                              -fx-background-color: #fafbfc;"/>
                        </VBox>
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Prix (€) *"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #445566;"/>
                            <TextField fx:id="txtPrix" promptText="Ex: 13.99"
                                       style="-fx-background-radius: 9; -fx-border-radius: 9;
                                              -fx-border-color: #e0e8f0; -fx-border-width: 1.5;
                                              -fx-padding: 11 14; -fx-font-size: 13px;
                                              -fx-background-color: #fafbfc;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="18">
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Catégorie *"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #445566;"/>
                            <ComboBox fx:id="comboCategorie" maxWidth="Infinity"
                                      style="-fx-background-radius: 9; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Fréquence *"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #445566;"/>
                            <ComboBox fx:id="comboFrequence" maxWidth="Infinity"
                                      style="-fx-background-radius: 9; -fx-font-size: 13px;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="7">
                        <Label text="Date de début *"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #445566;"/>
                        <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                    style="-fx-background-radius: 9; -fx-font-size: 13px;"/>
                    </VBox>

                    <Separator/>
                    <HBox spacing="12">
                        <Button text="✅  Ajouter l'abonnement" onAction="#ajouter"
                                style="-fx-background-color: #1a3a7a; -fx-text-fill: white;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-padding: 13 35; -fx-background-radius: 9; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(26,58,122,0.4), 8, 0, 0, 3);"/>
                        <Button text="Annuler" onAction="#retourListe"
                                style="-fx-background-color: white; -fx-text-fill: #556677;
                                       -fx-font-size: 13px; -fx-padding: 13 25;
                                       -fx-background-radius: 9; -fx-border-color: #dde3ea;
                                       -fx-border-radius: 9; -fx-border-width: 1.5; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>

</StackPane>