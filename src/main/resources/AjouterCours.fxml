<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AjouterCours"
            prefWidth="700.0" prefHeight="450.0">

    <children>
        <VBox spacing="14.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <padding>
                <Insets top="20" right="25" bottom="25" left="25"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button text="⬅ Retour"
                        onAction="#goListeCours"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #2563EB;
                               -fx-padding: 8 10;
                               -fx-background-radius: 10;"/>
                <Pane HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label text="Ajouter un Module de Formation"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;"
                   VBox.vgrow="NEVER"/>

            <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                <GridPane hgap="12" vgap="12" maxWidth="520"
                          style="-fx-background-color: white;
                 -fx-background-radius: 12;
                 -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, 3);">

                    <Label text="Titre du Module:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="tfNom" promptText="Ex: Gestion de Budget Personnel"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"
                               style="-fx-font-size: 14px;"/>

                    <Label text="Description Détaillée:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <VBox spacing="4" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <TextArea fx:id="taDescription"
                                  promptText="Exemple de description professionnelle:&#10;&#10;Ce module vous permettra de maîtriser les fondamentaux de la gestion budgétaire personnelle. Vous apprendrez à analyser vos revenus et dépenses, à identifier les opportunités d'économies, et à mettre en place un système de suivi efficace.&#10;&#10;Thèmes abordés:&#10;• Analyse des flux financiers&#10;• Techniques de budgétisation&#10;• Outils de suivi et tableaux de bord&#10;• Stratégies d'épargne&#10;• Planification financière à court et long terme"
                                  wrapText="true"
                                  prefRowCount="10"
                                  style="-fx-font-size: 13px;"/>
                        <Label text="💡 Conseil: Incluez les objectifs, thèmes abordés, et résultats attendus"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 11px; -fx-font-style: italic;"/>
                    </VBox>

                    <Button text="✅ Ajouter le Module"
                            onAction="#ajouterCours"
                            GridPane.rowIndex="2" GridPane.columnIndex="1"
                            style="-fx-background-color: #2E86DE;
                   -fx-text-fill: white;
                   -fx-font-size: 14px;
                   -fx-padding: 10 22;
                   -fx-background-radius: 10;"/>
                </GridPane>
            </VBox>

        </VBox>
    </children>
</AnchorPane>
