<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ModifierQuiz"
            stylesheets="@/app.css"
            prefWidth="1050.0" prefHeight="650.0">

    <left>
        <VBox prefWidth="230.0" styleClass="sidebar">
            <Label text="DINARI" styleClass="brand"/>
            <Label text="FINTECH MANAGEMENT" styleClass="brand-sub"/>

            <Separator opacity="0.2"/>

            <Button text="📘 Cours" styleClass="nav-btn" onAction="#goListeCours"/>
            <Button text="📝 Quiz" styleClass="nav-btn nav-btn-active" onAction="#goListeQuiz"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Label text="Utilisateur" styleClass="sidebar-footer"/>
            <Label text="admin@..." styleClass="sidebar-footer"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="14">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="⬅ Retour" styleClass="ghost-btn" onAction="#goListeQuiz"/>
                <Label text="Modifier Quiz" styleClass="page-title"/>
            </HBox>

            <GridPane hgap="12" vgap="12" maxWidth="720" styleClass="toolbar">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <Label text="ID Quiz:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="tfIdQuiz"
                           editable="false"
                           styleClass="input"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="ID Cours:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="tfIdCours"
                           promptText="Ex: 1"
                           styleClass="input"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Titre:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="tfTitre"
                           promptText="Ex: Quiz Java"
                           styleClass="input"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Réponses (séparées par ;):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="tfReponses"
                           promptText="A;B;C;D"
                           styleClass="input"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Réponse correcte:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="tfCorrecte"
                           promptText="Ex: B"
                           styleClass="input"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Score:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="tfScore"
                           promptText="Ex: 10"
                           styleClass="input"
                           GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <Label text="Mode Examen:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <CheckBox fx:id="cbExamMode" text="Activer le mode examen avec chronomètre"
                          GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <Label text="Temps limite (minutes):" GridPane.rowIndex="7" GridPane.columnIndex="0" fx:id="lblTimeLimit"/>
                <TextField fx:id="tfTimeLimit" promptText="Ex: 5" styleClass="input"
                           GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <HBox spacing="10" GridPane.rowIndex="8" GridPane.columnIndex="1">
                    <Button text="Enregistrer" styleClass="primary-btn" onAction="#save"/>
                    <Button text="Annuler" styleClass="ghost-btn" onAction="#goListeQuiz"/>
                </HBox>

            </GridPane>

        </VBox>
    </center>

</BorderPane>
