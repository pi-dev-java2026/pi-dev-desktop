<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane prefHeight="720" prefWidth="1200" stylesheets="@app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.BudgetLayoutController">

    <!-- TOP -->
    <top>
        <HBox spacing="10" style="-fx-background-color: white;">
            <padding>
                <Insets bottom="14" left="14" right="14" top="14" />
            </padding>

            <Button fx:id="tabPlanif" onAction="#goPlanificationList" styleClass="top-tab" text="Planification" />

            <Button fx:id="tabActivite" onAction="#goActiviteList" styleClass="top-tab" text="Activité" />
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: #f4f6fb;" />
    </center>

</BorderPane>
